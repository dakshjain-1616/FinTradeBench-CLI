# ─── Required for real benchmarks ────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here
# Get a key at: https://openrouter.ai

# ─── Model selection ──────────────────────────────────────────────────────────
# Set DEFAULT_MODEL to skip passing --model on every run:
#   python benchmark.py            (uses DEFAULT_MODEL)
#   python benchmark.py --model X  (overrides DEFAULT_MODEL)
# Run `python benchmark.py --list-models` to see all options.

# Premium — best accuracy (1M+ context):
# DEFAULT_MODEL=openai/gpt-5.4-pro                   # OpenAI flagship
# DEFAULT_MODEL=openai/gpt-5.4                        # GPT-5.4 (1M ctx)
# DEFAULT_MODEL=anthropic/claude-opus-4.6             # Anthropic flagship (1M ctx)
# DEFAULT_MODEL=anthropic/claude-sonnet-4.6           # Anthropic fast + smart
# DEFAULT_MODEL=x-ai/grok-4.20-beta                   # xAI Grok 4.20 (2M ctx)

# Budget — great value:
DEFAULT_MODEL=deepseek/deepseek-chat                  # Budget  — great default
# DEFAULT_MODEL=openai/gpt-5.4-mini                   # Budget  — GPT-5.4 Mini
# DEFAULT_MODEL=openai/gpt-5.4-nano                   # Budget  — GPT-5.4 Nano
# DEFAULT_MODEL=mistralai/mistral-small-2603          # Budget  — Mistral Small 4
# DEFAULT_MODEL=deepseek/deepseek-r1                  # Budget  — strong reasoning
# DEFAULT_MODEL=google/gemini-2.0-flash-001           # Budget  — fast Gemini
# DEFAULT_MODEL=qwen/qwen-2.5-72b-instruct            # Budget  — multilingual

# Free tier — no credits needed:
# DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b     # Free    — NVIDIA 120B
# DEFAULT_MODEL=qwen/qwen3.5-9b                       # Free    — Qwen 3.5 9B
# DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct     # Free    — best open model

# ─── Optional ─────────────────────────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
REPORTS_DIR=reports      # where JSON/HTML reports are saved
MAX_QUESTIONS=0          # 0 = no limit; set e.g. 10 for a quick test run
